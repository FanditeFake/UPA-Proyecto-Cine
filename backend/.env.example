# ── Servidor ──────────────────────────────
PORT=4000

# ── Base de datos (MySQL en Docker, entorno LOCAL) ───────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=cinemax_db
DB_USER=cinemax_user
DB_PASSWORD=cinemax_pass

# ── JWT (autenticación) ───────────────────
JWT_SECRET=cambia_esto_por_una_cadena_larga_y_segura
JWT_EXPIRES_IN=8h

# ==========================================================
#  PRODUCCIÓN / AZURE  (configurar como "App settings" en el
#  Azure App Service; NO se ponen en este archivo en la nube)
# ==========================================================
# DB_HOST=<tu-servidor>.mysql.database.azure.com
# DB_PORT=3306
# DB_NAME=cinemax_db
# DB_USER=<usuario_admin_mysql>
# DB_PASSWORD=<contraseña>
# DB_SSL=true                       # Azure MySQL exige conexión SSL
# DB_SSL_REJECT_UNAUTHORIZED=true   # ponlo en false solo si falla la verificación del certificado
# JWT_SECRET=<cadena larga y única para producción>
